# Supabase — from your project's API settings (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server only — NEVER expose to the browser. Used by route handlers for storage/export.
SUPABASE_SERVICE_ROLE_KEY=

# Gemini — server-side only (kept out of the browser, an upgrade over the old tool)
GEMINI_API_KEY=
# Optional override; defaults to gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash

# Optional: the deployed origin, used to build absolute links in emails/exports
NEXT_PUBLIC_SITE_URL=http://localhost:3000
